#!/usr/bin/env bash
# Pre-commit git hook — fast checks only (format + analyze)
# Runs on every commit. Keeps feedback loop tight.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── Ensure dart/flutter are on PATH regardless of how git was launched ─────────
# JetBrains and other IDEs may not inherit the shell PATH.
FLUTTER_BIN="/home/develop4god/development/flutter/bin"
DART_BIN="/home/develop4god/development/flutter/bin/cache/dart-sdk/bin"
export PATH="$FLUTTER_BIN:$DART_BIN:$PATH"

# Verify dart is available
if ! command -v dart &>/dev/null; then
  echo "[pre-commit] ❌ 'dart' not found in PATH. Check FLUTTER_BIN in .githooks/pre-commit" >&2
  exit 1
fi

echo "[pre-commit] Running fast checks (format + analyze)..."

# ── 1. Format check — only staged Dart files in lib/ or test/ ─────────────────
STAGED_DART=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep '\.dart$' \
  | grep -E '^(lib|test)/' \
  | sed "s|^|$REPO_ROOT/|" \
  || true)

if [[ -z "$STAGED_DART" ]]; then
  echo "[pre-commit] ℹ️  No staged Dart files — skipping format check."
else
  if ! echo "$STAGED_DART" | xargs dart format --output=none --set-exit-if-changed; then
    echo "" >&2
    echo "[pre-commit] ❌ Formatting issues found in staged files." >&2
    echo "[pre-commit]    Fix: dart format lib test" >&2
    echo "[pre-commit]    Then: git add the reformatted files and commit again." >&2
    exit 1
  fi
  echo "[pre-commit] ✅ Format OK"
fi

# ── 2. Static analysis ─────────────────────────────────────────────────────────
if ! dart analyze "$REPO_ROOT" 2>&1; then
  echo "" >&2
  echo "[pre-commit] ❌ dart analyze failed. Fix issues above before committing." >&2
  exit 1
fi

# ── 3. GitHub Actions workflow lint — only staged workflow files ──────────────
mapfile -d '' -t STAGED_WORKFLOWS < <(git -c core.quotepath=false diff --cached --name-only --diff-filter=ACMR -z \
  | grep -zE '^\.github/workflows/.*\.ya?ml$' \
  || true)

if [[ ${#STAGED_WORKFLOWS[@]} -eq 0 ]]; then
  echo "[pre-commit] ℹ️  No staged workflow files — skipping actionlint."
elif ! command -v actionlint &>/dev/null; then
  echo "[pre-commit] ⚠️  actionlint not found in PATH — skipping workflow lint." >&2
  echo "[pre-commit]    Install: https://github.com/rhysd/actionlint" >&2
else
  STAGED_WORKFLOW_PATHS=("${STAGED_WORKFLOWS[@]/#/$REPO_ROOT/}")
  if ! actionlint "${STAGED_WORKFLOW_PATHS[@]}"; then
    echo "" >&2
    echo "[pre-commit] ❌ actionlint found issues in staged workflow files." >&2
    exit 1
  fi
  echo "[pre-commit] ✅ Workflow lint OK"
fi

echo "[pre-commit] ✅ Fast checks passed — commit allowed."
exit 0
